{
  "manifest_version": 3,
  "name": "Auction Pricing Assistant",
  "version": "1.0.0",
  "description": "CatBoost pricing estimates for OPENLANE / Velocicast auction vehicles.",

  "permissions": ["activeTab", "storage"],

  "host_permissions": [
    "https://*.velocicast.io/*",
    "https://*.velocicast.com/*",
    "https://*.openlane.ca/*",
    "https://*.run.app/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://*.velocicast.io/*",
        "https://*.velocicast.com/*",
        "https://*.openlane.ca/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "action": {
    "default_title": "Auction Pricing Assistant – Batch Estimate Visible",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
